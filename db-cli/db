#!/usr/bin/env bash
#
# db - Anarock staging database CLI
#
# Usage:
#   db query <database> "<SQL>" [--limit N]
#   db es <index> "<JSON>"
#   db es indices [--all]
#   db es mapping <index>

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

PYTHON="$SCRIPT_DIR/venv/bin/python3"
if [[ ! -x "$PYTHON" ]]; then
  PYTHON="python3"
fi
VERSION="2.0.0"

if [[ -f "$SCRIPT_DIR/.env" ]]; then
  set -a
  source "$SCRIPT_DIR/.env"
  set +a
fi

RED=''
GREEN=''
YELLOW=''
NC=''
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  NC='\033[0m'
fi

error() {
  echo -e "${RED}Error: $1${NC}" >&2
  exit 1
}

info() {
  echo -e "${GREEN}$1${NC}" >&2
}

resolve_db_alias() {
  local db="$1"

  case "$db" in
    leads|lead)           echo "anarock_leads_production" ;;
    users|user|employee)  echo "anarock_employee_production" ;;
    digix)                echo "anarock_digix_prod" ;;
    genie|genie_be)       echo "genie" ;;
    calling|telephony)    echo "anarock_calling_production" ;;
    finance|plutus)       echo "anarock_plutus_production" ;;
    analytics|marketing)  echo "anarock_analytics" ;;
    *)                    echo "$db" ;;
  esac
}

get_auth_token_file() {
  echo "$SCRIPT_DIR/auth_token_staging.txt"
}

load_auth_token() {
  local token_file
  token_file=$(get_auth_token_file)
  if [[ -f "$token_file" ]]; then
    tr -d '\n' < "$token_file"
  else
    return 1
  fi
}

ensure_auth_token() {
  local token
  if ! token=$(load_auth_token); then
    info "No staging auth token found, running login..."
    "$PYTHON" "$SCRIPT_DIR/anarock_login.py" >&2
    token=$(load_auth_token)
  fi
  echo "$token"
}

urlencode_sql() {
  SQL_QUERY="$1" "$PYTHON" -c "import os, urllib.parse; print(urllib.parse.quote(os.environ['SQL_QUERY']))"
}

run_sql_query() {
  local dbname="$1"
  local sql="$2"
  local limit="${3:-}"
  local query_url="${SQL_QUERY_URL_STAGING:-https://marketing-dashboards.staging.anarock.com/query}"
  local resolved_db
  local safe_sql="$sql"

  resolved_db=$(resolve_db_alias "$dbname")

  if [[ ! "$sql" =~ [Ww][Hh][Ee][Rr][Ee] ]] && [[ ! "$sql" =~ [Gg][Rr][Oo][Uu][Pp] ]] && [[ ! "$sql" =~ [Ll][Ii][Mm][Ii][Tt] ]]; then
    safe_sql="${sql%;}"
    safe_sql="$safe_sql LIMIT 10000"
  fi

  if [[ -n "$limit" ]] && [[ ! "$sql" =~ [Ll][Ii][Mm][Ii][Tt] ]]; then
    safe_sql="${sql%;}"
    safe_sql="$safe_sql LIMIT $limit"
  fi

  local token
  token=$(ensure_auth_token)

  local response
  response=$(curl -s -L -k -w "\n%{http_code}" \
    "$query_url" \
    -H "accept: application/json, text/plain, */*" \
    -H "content-type: application/x-www-form-urlencoded" \
    -H "origin: ${query_url%/query}" \
    -H "referer: ${query_url%/query}/" \
    -H "user-agent: Mozilla/5.0" \
    -H "Cookie: auth_token=${token};sessionid=1" \
    -d "dbname=${resolved_db}&sql=$(urlencode_sql "$safe_sql")")

  local http_code
  local body
  http_code=$(echo "$response" | tail -n1)
  body=$(echo "$response" | sed '$d')

  if [[ "$http_code" == "200" ]] && echo "$body" | grep -q "redirect_to="; then
    info "Auth token expired, re-logging in..."
    "$PYTHON" "$SCRIPT_DIR/anarock_login.py" >&2
    token=$(load_auth_token)

    response=$(curl -s -L -k -w "\n%{http_code}" \
      "$query_url" \
      -H "accept: application/json, text/plain, */*" \
      -H "content-type: application/x-www-form-urlencoded" \
      -H "origin: ${query_url%/query}" \
      -H "referer: ${query_url%/query}/" \
      -H "user-agent: Mozilla/5.0" \
      -H "Cookie: auth_token=${token};sessionid=1" \
      -d "dbname=${resolved_db}&sql=$(urlencode_sql "$safe_sql")")

    http_code=$(echo "$response" | tail -n1)
    body=$(echo "$response" | sed '$d')
  fi

  if [[ "$http_code" != "200" ]]; then
    error "API request failed with HTTP $http_code: $body"
  fi

  echo "$body"
}

get_es_sid_file() {
  echo "$SCRIPT_DIR/es_sid_staging.txt"
}

load_es_sid() {
  local sid_file
  sid_file=$(get_es_sid_file)
  if [[ -f "$sid_file" ]]; then
    tr -d '\n' < "$sid_file"
  else
    return 1
  fi
}

ensure_es_sid() {
  local sid
  if ! sid=$(load_es_sid); then
    info "No staging ES session found, running login..."
    if ! "$PYTHON" "$SCRIPT_DIR/kibana_login.py" >&2; then
      error "ES login failed. Set KIBANA_USERNAME_STAGING and KIBANA_PASSWORD_STAGING, or provide es_sid_staging.txt."
    fi
    if ! sid=$(load_es_sid); then
      error "ES login did not create es_sid_staging.txt"
    fi
  fi
  echo "$sid"
}

run_es_query() {
  local path="$1"
  local body="$2"
  local kibana_url="${KIBANA_URL_STAGING:-https://es-search.staging.anarock.com:5601}"
  local kbn_version="${KIBANA_VERSION_STAGING:-8.3.2}"
  local sid

  if ! sid=$(ensure_es_sid); then
    exit 1
  fi

  local curl_args=(-s -L -k -w "\n%{http_code}" -X POST)
  curl_args+=("${kibana_url}/api/console/proxy?path=${path}&method=GET")
  curl_args+=(-H "accept: */*")
  curl_args+=(-H "content-type: application/json")
  curl_args+=(-H "kbn-build-number: 83335")
  curl_args+=(-H "kbn-version: ${kbn_version}")
  curl_args+=(-H "origin: ${kibana_url}")
  curl_args+=(-H "referer: ${kibana_url}/app/dev_tools")
  curl_args+=(-H "user-agent: Mozilla/5.0")
  curl_args+=(-H "x-elastic-internal-origin: Kibana")
  curl_args+=(-H "Cookie: sid=${sid}")

  local response
  if [[ -n "$body" ]]; then
    response=$(curl "${curl_args[@]}" -d "$body")
  else
    response=$(curl "${curl_args[@]}")
  fi

  local http_code
  local body_response
  http_code=$(echo "$response" | tail -n1)
  body_response=$(echo "$response" | sed '$d')

  if [[ "$http_code" == "401" ]] || echo "$body_response" | grep -qi "unauthorized"; then
    info "ES session expired, re-logging in..."
    if ! "$PYTHON" "$SCRIPT_DIR/kibana_login.py" >&2; then
      error "ES login failed. Set KIBANA_USERNAME_STAGING and KIBANA_PASSWORD_STAGING, or provide es_sid_staging.txt."
    fi
    if ! sid=$(load_es_sid); then
      error "ES login did not create es_sid_staging.txt"
    fi

    curl_args=()
    curl_args+=(-s -L -k -w "\n%{http_code}" -X POST)
    curl_args+=("${kibana_url}/api/console/proxy?path=${path}&method=GET")
    curl_args+=(-H "accept: */*")
    curl_args+=(-H "content-type: application/json")
    curl_args+=(-H "kbn-build-number: 83335")
    curl_args+=(-H "kbn-version: ${kbn_version}")
    curl_args+=(-H "origin: ${kibana_url}")
    curl_args+=(-H "referer: ${kibana_url}/app/dev_tools")
    curl_args+=(-H "user-agent: Mozilla/5.0")
    curl_args+=(-H "x-elastic-internal-origin: Kibana")
    curl_args+=(-H "Cookie: sid=${sid}")

    if [[ -n "$body" ]]; then
      response=$(curl "${curl_args[@]}" -d "$body")
    else
      response=$(curl "${curl_args[@]}")
    fi

    http_code=$(echo "$response" | tail -n1)
    body_response=$(echo "$response" | sed '$d')
  fi

  if [[ "$http_code" != "200" ]]; then
    error "ES request failed with HTTP $http_code: $body_response"
  fi

  echo "$body_response"
}

es_encode_path() {
  local path="$1"
  ES_PATH="$path" "$PYTHON" -c "import os, urllib.parse; print(urllib.parse.quote(os.environ['ES_PATH'], safe=''))"
}

validate_json() {
  local json_str="$1"
  if ! JSON_STR="$json_str" "$PYTHON" -c "import json, os; json.loads(os.environ['JSON_STR'])" 2>/dev/null; then
    error "Invalid JSON: $json_str"
  fi
}

show_help() {
  cat << 'EOF'
db - Anarock staging database CLI

USAGE:
    db <command> [args...]

OPTIONS:
    -h, --help      Show this help message
    -v, --version   Show version

COMMANDS:
    query <database> "<SQL>" [--limit N]
    es <index> "<query_json>"
    es indices [--all]
    es mapping <index>

DATABASE ALIASES:
    leads
    users
    digix
    genie      -> genie
    calling
    finance
    analytics

EXAMPLE:
    db query leads "SELECT id, name FROM leads LIMIT 5"
    db es agent_cp_project_mappings '{"query": {"match_all": {}}, "size": 10}'
    db es indices

EOF
}

cmd_query() {
  if [[ $# -lt 2 ]]; then
    error "Usage: db query <database> \"<SQL>\" [--limit N]"
  fi

  local dbname="$1"
  local sql="$2"
  local limit=""

  if [[ -z "$dbname" ]]; then
    error "Database name is required"
  fi
  if [[ -z "$sql" ]]; then
    error "SQL query is required"
  fi

  if [[ $# -ge 4 ]] && [[ "$3" == "--limit" ]]; then
    limit="$4"
  fi

  if [[ -n "$limit" ]] && [[ ! "$limit" =~ ^[0-9]+$ ]]; then
    error "Limit must be a positive integer"
  fi

  run_sql_query "$dbname" "$sql" "$limit"
}

cmd_es() {
  if [[ $# -eq 0 ]]; then
    error "Usage: db es <index> \"<query_json>\" | db es indices [--all] | db es mapping <index>"
  fi

  local subcommand="$1"
  shift

  case "$subcommand" in
    indices)
      local include_system=""
      if [[ $# -gt 0 ]] && [[ "$1" == "--all" ]]; then
        include_system="true"
      fi
      cmd_es_indices "$include_system"
      ;;
    mapping)
      if [[ $# -eq 0 ]]; then
        error "Usage: db es mapping <index>"
      fi
      cmd_es_mapping "$1"
      ;;
    *)
      if [[ $# -lt 1 ]]; then
        error "Usage: db es <index> \"<query_json>\""
      fi
      cmd_es_search "$subcommand" "$1"
      ;;
  esac
}

cmd_es_indices() {
  local include_system="$1"
  local path
  path=$(es_encode_path "_aliases")

  local result
  result=$(run_es_query "$path" "")

  ES_RESULT="$result" ES_INCLUDE_SYSTEM="$include_system" "$PYTHON" << 'PYEOF'
import json
import os

result = json.loads(os.environ["ES_RESULT"])
include_system = os.environ.get("ES_INCLUDE_SYSTEM", "")

if isinstance(result, dict):
    indices = list(result.keys())
    if not include_system:
        indices = [index for index in indices if not index.startswith(".")]
    print(json.dumps(sorted(indices), indent=2))
else:
    print(json.dumps(result, indent=2))
PYEOF
}

cmd_es_mapping() {
  local index="$1"
  local path
  path=$(es_encode_path "${index}/_mapping")
  run_es_query "$path" ""
}

cmd_es_search() {
  local index="$1"
  local query="$2"

  if [[ -z "$index" ]]; then
    error "Index name is required"
  fi

  validate_json "$query"

  local path
  path=$(es_encode_path "${index}/_search")
  run_es_query "$path" "$query"
}

main() {
  if [[ $# -eq 0 ]]; then
    show_help
    exit 0
  fi

  case "$1" in
    -h|--help)
      show_help
      exit 0
      ;;
    -v|--version)
      echo "db $VERSION"
      exit 0
      ;;
    query)
      shift
      cmd_query "$@"
      ;;
    es)
      shift
      cmd_es "$@"
      ;;
    *)
      error "Unknown command: $1. Use 'db --help' for usage."
      ;;
  esac
}

main "$@"
